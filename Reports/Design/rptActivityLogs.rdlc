                <TablixCell>
                  <CellContents>
                    <Textbox Name="TimeOut">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>=IIf(
    IsNothing(Fields!TimeOut.Value) 
    OR Fields!TimeOut.Value = "",
    "IN SESSION",
    Format(CDate(Fields!TimeOut.Value), "MMM dd, yyyy hh:mm tt")
)</Value>
                              <Style />
                            </TextRun>
                          </TextRuns>
                          <Style>
